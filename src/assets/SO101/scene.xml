            <geom type="box" size="0.09 0.09 0.005" pos="0 0 0.005" rgba="0.65 0.45 0.25 1"/>
            <geom type="box" size="0.09 0.005 0.02" pos="0  0.095 0.025" rgba="0.65 0.45 0.25 1"/>
            <geom type="box" size="0.09 0.005 0.02" pos="0 -0.095 0.025" rgba="0.65 0.45 0.25 1"/>
            <geom type="box" size="0.005 0.09 0.02" pos="-0.095 0 0.025" rgba="0.65 0.45 0.25 1"/>
            <geom type="box" size="0.005 0.09 0.02" pos=" 0.095 0 0.025" rgba="0.65 0.45 0.25 1"/>
        </body>

        <!-- Pepperoni slices: radius 2.5cm, 6mm thick, stacked in bin center -->
        <body name="pepperoni_1" pos="0.35 0.30 0.013">
            <geom type="cylinder" size="0.025 0.003" rgba="0.72 0.12 0.08 1"/>
        </body>
        <body name="pepperoni_2" pos="0.35 0.30 0.019">
            <geom type="cylinder" size="0.025 0.003" rgba="0.72 0.12 0.08 1"/>
